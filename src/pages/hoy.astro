---
import daily from "../../data/daily.json";
import BaseLayout from "../layouts/BaseLayout.astro";
import NewsCard from "../components/NewsCard.astro";

function formatDate(iso) {
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return iso;
  return new Intl.DateTimeFormat("es-ES", { dateStyle: "medium", timeStyle: "short" }).format(d);
}
---

<BaseLayout title={`${daily.title} — ${daily.date}`}>
  <div class="meta" style="justify-content: space-between;">
    <span>{formatDate(daily.date)}</span>
    <a href="/">Inicio</a>
  </div>

  <h1 class="h1">{daily.title}</h1>

  <section class="card" style="margin-top: 16px;">
    <h2 style="margin:0 0 10px;">Top del día</h2>
    <div class="stack">
      {daily.top?.map((n) => <NewsCard item={n} />)}
    </div>
  </section>

  {daily.sections?.map((s) => (
    <section>
      <div class="sectionTitle">{s.name}</div>
      <div class="stack">
        {s.items?.map((n) => <NewsCard item={n} showWhy={false} />)}
      </div>
    </section>
  ))}
</BaseLayout>