---
const { title } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600&family=Source+Serif+4:opsz,wght@9..14,400;9..14,500;9..14,600&family=Libre+Franklin:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        color-scheme: light;
        --page-bg: #f4efe4;
        --page-ink: #111015;
        --muted: #5b554b;
        --accent: #326891;
        --rule: #d9d2c4;
        --headline-font: "Playfair Display", "Fraunces", "Times New Roman", serif;
        --body-font: "Source Serif 4", "Georgia", serif;
        --meta-font: "Libre Franklin", "News Cycle", "Helvetica Neue", sans-serif;
        --transition: 220ms cubic-bezier(0.16, 1, 0.3, 1);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: var(--body-font);
        background: var(--page-bg);
        background-image: radial-gradient(circle at 0% 0%, rgba(255, 255, 255, 0.45), transparent 60%),
          radial-gradient(circle at 100% 0%, rgba(255, 255, 255, 0.35), transparent 55%);
        color: var(--page-ink);
        min-height: 100vh;
        font-size: 1.05rem;
        line-height: 1.7;
      }

      body::selection {
        background: rgba(50, 104, 145, 0.25);
        color: var(--page-ink);
      }

      .scene {
        padding: clamp(24px, 6vw, 64px) 0 clamp(48px, 8vw, 96px);
      }

      .wrap {
        max-width: 1080px;
        margin: 0 auto;
        padding: 0 clamp(18px, 4vw, 52px);
      }

      .page-shell {
        background: #fff;
        border-left: 1px solid var(--rule);
        border-right: 1px solid var(--rule);
        padding: clamp(24px, 4vw, 56px) clamp(18px, 4vw, 64px) clamp(56px, 6vw, 96px);
        box-shadow: 0 35px 75px rgba(17, 16, 21, 0.08);
        position: relative;
      }

      .page-shell::before,
      .page-shell::after {
        content: "";
        position: absolute;
        left: clamp(24px, 4vw, 64px);
        right: clamp(24px, 4vw, 64px);
        height: 1px;
        background: var(--rule);
        opacity: 0.9;
      }

      .page-shell::before {
        top: clamp(24px, 4vw, 48px);
      }

      .page-shell::after {
        bottom: clamp(40px, 5vw, 72px);
      }

      .masthead {
        text-align: left;
        margin-bottom: clamp(28px, 5vw, 56px);
      }

      .masthead__meta {
        justify-content: center;
        gap: clamp(12px, 4vw, 48px);
        margin-bottom: 12px;
      }

      .masthead__breadcrumb {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-family: var(--meta-font);
        font-size: 0.78rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        margin-top: clamp(12px, 2vw, 18px);
      }

      .masthead__breadcrumb a {
        color: inherit;
        text-decoration: none;
        transition: color var(--transition);
      }

      .masthead__breadcrumb a:hover {
        color: var(--accent);
      }

      .masthead__breadcrumbCurrent {
        letter-spacing: 0.12em;
        text-transform: none;
      }

      .masthead__titles {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: clamp(16px, 4vw, 48px);
        flex-wrap: wrap;
        padding: clamp(8px, 2vw, 16px) 0;
      }

      .masthead__titles .h1 {
        margin: 0;
        text-align: left;
      }

      .masthead__titles .h2 {
        margin: 0;
        text-align: right;
        flex: 1;
      }

      .masthead__ticker {
        display: flex;
        justify-content: center;
        gap: 16px;
        flex-wrap: wrap;
        font-family: var(--meta-font);
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.25em;
        padding-top: 14px;
        border-top: 1px solid var(--rule);
      }

      .masthead__ticker span,
      .masthead__ticker a {
        padding-right: 14px;
        margin-right: 14px;
        border-right: 1px solid var(--rule);
        display: inline-flex;
        align-items: center;
        gap: 6px;
      }

      .masthead__ticker span:last-child,
      .masthead__ticker a:last-child {
        margin-right: 0;
        padding-right: 0;
        border-right: none;
      }

      .masthead__ticker a {
        color: inherit;
        text-decoration: none;
        transition: color var(--transition);
      }

      .masthead__ticker a:hover {
        color: var(--accent);
      }

      .site-footer {
        margin-top: clamp(48px, 8vw, 120px);
        padding-top: clamp(18px, 3vw, 32px);
        border-top: 1px solid var(--rule);
        font-family: var(--meta-font);
        font-size: 0.72rem;
        letter-spacing: 0.12em;
        color: var(--muted);
      }

      .site-footer__line {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        align-items: center;
        width: 100%;
      }

      .site-footer__chunk {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        text-transform: uppercase;
      }

      .site-footer__chunk--right {
        margin-left: auto;
      }

      .site-footer__brand {
        font-family: var(--headline-font);
        font-size: 0.85rem;
        letter-spacing: 0.05em;
        text-transform: none;
        color: var(--page-ink);
      }

      .site-footer__nav {
        text-transform: none;
        letter-spacing: 0.08em;
      }

      .site-footer__nav a {
        color: inherit;
        text-decoration: none;
      }

      .site-footer__nav a:hover {
        color: var(--accent);
        text-decoration: underline;
      }

      .site-footer__navItem {
        display: inline-flex;
        align-items: center;
        gap: 4px;
      }

      .h1 {
        font-family: var(--headline-font);
        font-size: clamp(2.7rem, 5.85vw, 4.14rem);
        letter-spacing: 0.02em;
        text-transform: uppercase;
        text-align: left;
        margin: clamp(8px, 2vw, 16px) 0 0;
        font-weight: 600;
      }

      .h2.principal {
        font-family: var(--body-font);
        font-size: clamp(1.0125rem, 2.25vw, 1.44rem);
        margin: clamp(8px, 2vw, 12px) 0;
        text-align: right;
        max-width: 840px;
        font-style: italic;
        color: var(--muted);
        letter-spacing: 0.01em;
      }

      .meta {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        font-family: var(--meta-font);
        font-size: 0.82rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--muted);
      }

      .meta--compact {
        letter-spacing: 0.12em;
        font-size: 0.75rem;
      }

      .meta-eyebrow {
        border-top: none;
        padding-top: 0;
      }

      .meta-spread {
        justify-content: space-between;
        align-items: center;
        gap: 16px;
      }

      .card {
        border: none;
        padding: 0;
        background: none;
        border-bottom: 1px solid var(--rule);
      }

      .card:hover {
        background: none;
      }

      .featured-card {
        margin: clamp(28px, 5vw, 48px) 0;
        padding-bottom: clamp(28px, 4vw, 40px);
        border-top: 3px double var(--page-ink);
        border-bottom: 1px solid var(--rule);
      }

      .stack {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: clamp(18px, 3vw, 36px);
      }

      .lede-grid {
        display: grid;
        grid-template-columns: minmax(0, 2fr) minmax(0, 1fr);
        gap: clamp(24px, 4vw, 48px);
        margin-bottom: clamp(28px, 5vw, 56px);
        border-bottom: 1px solid var(--rule);
        padding-bottom: clamp(24px, 4vw, 40px);
      }

      .lede-primary {
        padding-right: clamp(18px, 3vw, 40px);
        border-right: 1px solid var(--rule);
      }

      .lede-primary__eyebrow {
        font-family: var(--meta-font);
        text-transform: uppercase;
        letter-spacing: 0.28em;
        font-size: 0.78rem;
        color: var(--muted);
      }

      .lede-primary__title {
        display: block;
        margin: 12px 0 16px;
        font-family: var(--headline-font);
        font-size: clamp(2.2rem, 4.5vw, 3.1rem);
        line-height: 1.25;
      }

      .lede-secondary .sectionTitle {
        margin-bottom: 18px;
      }

      .lede-secondary__list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 18px;
      }

      .lede-secondary__item {
        border-bottom: 1px solid var(--rule);
        padding-bottom: 18px;
      }

      .lede-secondary__item:last-child {
        border-bottom: none;
        padding-bottom: 0;
      }

      .lede-secondary__link {
        font-family: var(--headline-font);
        font-size: 1.2rem;
        line-height: 1.35;
      }

      .lede-secondary__empty {
        font-family: var(--meta-font);
        text-transform: uppercase;
        letter-spacing: 0.2em;
        font-size: 0.75rem;
        color: var(--muted);
      }

      section + section {
        margin-top: clamp(28px, 4vw, 46px);
        padding-top: clamp(12px, 2vw, 18px);
        border-top: 1px solid var(--rule);
      }

      .sectionTitle {
        margin: 0 0 12px;
        font-family: var(--meta-font);
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.3em;
        color: var(--muted);
      }

      .sectionHeading {
        margin: 12px 0;
        font-family: var(--headline-font);
        font-size: 1.6rem;
        font-weight: 600;
        letter-spacing: 0.01em;
      }

      p {
        margin: 6px 0 0;
        color: rgba(17, 16, 21, 0.88);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      a:hover {
        color: var(--accent);
        text-decoration: underline;
        text-decoration-thickness: 2px;
      }

      .news-card {
        padding: clamp(14px, 2vw, 24px) 0;
        display: grid;
        gap: 6px;
      }

      .news-link {
        font-family: var(--headline-font);
        font-size: 1.45rem;
        line-height: 1.3;
      }

      .tag-row {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 12px;
      }

      .tag-label {
        font-family: var(--meta-font);
        font-size: 0.68rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--muted);
        font-weight: 600;
      }

      .section-label {
        display: inline-flex;
        font-family: var(--meta-font);
        text-transform: uppercase;
        letter-spacing: 0.25em;
        font-size: 0.72rem;
        color: var(--muted);
        padding-top: 10px;
        border-top: 2px solid var(--page-ink);
      }

      .digest-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 24px;
      }

      .digest-card {
        border-bottom: 1px solid var(--rule);
        padding-bottom: 18px;
      }

      .digest-card__title {
        display: block;
        font-family: var(--headline-font);
        font-size: 1.25rem;
        margin-bottom: 8px;
        line-height: 1.35;
      }

      @media (max-width: 720px) {
        body {
          font-size: 1rem;
        }

        .page-shell::before,
        .page-shell::after {
          left: 18px;
          right: 18px;
        }

        .h1 {
          font-size: 2.4rem;
        }

        .h2.principal {
          font-size: 1.9rem;
        }

        .stack {
          grid-template-columns: 1fr;
        }

        .lede-grid {
          grid-template-columns: 1fr;
        }

        .lede-primary {
          border-right: none;
          padding-right: 0;
          border-bottom: 1px solid var(--rule);
          margin-bottom: 24px;
          padding-bottom: 24px;
        }

        .masthead__meta {
          flex-direction: column;
          text-align: center;
        }

        .meta {
          letter-spacing: 0.1em;
        }

        .meta-spread {
          flex-direction: column;
          align-items: flex-start;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        * {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
        }
      }
    </style>
  </head>
  <body>
    <div id="top" class="scene">
      <main class="wrap page-shell">
        <slot />
      </main>
    </div>
  </body>
</html>
