---
const { title } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <style is:global>
      :root { color-scheme: light dark; }
      body { margin: 0; font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif; }
      .wrap { max-width: 980px; margin: 0 auto; padding: 24px; }
      .card { border: 1px solid rgba(127,127,127,.25); border-radius: 16px; padding: 16px; background: rgba(127,127,127,.06); }
      .h1 { font-size: 28px; margin: 0; letter-spacing: -0.02em; }
      .meta { display: flex; gap: 10px; flex-wrap: wrap; font-size: 13px; opacity: .75; }
      .pill { display: inline-block; padding: 4px 10px; border-radius: 999px; font-size: 12px; border: 1px solid rgba(127,127,127,.25); }
      .stack { display: grid; gap: 12px; }
      a { color: inherit; }
      p { margin: 8px 0 0; line-height: 1.5; }
      .sectionTitle { margin: 28px 0 12px; font-size: 14px; opacity: .75; text-transform: uppercase; letter-spacing: .08em; }
    </style>
  </head>
  <body>
    <main class="wrap">
      <slot />
    </main>
  </body>
</html>