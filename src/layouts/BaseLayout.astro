---
const { title } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Sora:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        color-scheme: light;
        --bg: #e6ebf5;
        --bg-raised: #eff3fb;
        --bg-contrast: #fdfefe;
        --text: #1f2337;
        --muted: #6e7797;
        --accent: #6c7dff;
        --shadow-soft: 28px 28px 60px rgba(163, 177, 198, 0.55), -24px -24px 50px rgba(255, 255, 255, 0.9);
        --shadow-hover: 14px 14px 30px rgba(163, 177, 198, 0.45), -10px -10px 25px rgba(255, 255, 255, 0.8);
        --shadow-inset: inset 10px 10px 25px rgba(163, 177, 198, 0.4), inset -10px -10px 25px rgba(255, 255, 255, 0.95);
        --radius-lg: 28px;
        --radius-md: 18px;
        --transition: 280ms cubic-bezier(0.16, 1, 0.3, 1);
      }

      body[data-theme="dark"] {
        color-scheme: dark;
        --bg: #0f111b;
        --bg-raised: #161a28;
        --bg-contrast: #1f2435;
        --text: #f4f6ff;
        --muted: #a8b1d6;
        --accent: #89a8ff;
        --shadow-soft: 24px 24px 50px rgba(4, 6, 11, 0.85), -18px -18px 40px rgba(34, 39, 61, 0.6);
        --shadow-hover: 16px 16px 32px rgba(4, 6, 11, 0.8), -12px -12px 30px rgba(34, 39, 61, 0.55);
        --shadow-inset: inset 8px 8px 20px rgba(4, 6, 11, 0.85), inset -8px -8px 22px rgba(34, 39, 61, 0.65);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: "Space Grotesk", "Sora", "Segoe UI", system-ui, -apple-system, sans-serif;
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
      }

      body::selection {
        background: var(--accent);
        color: #fff;
      }

      body[data-theme="dark"]::selection {
        background: #f4f6ff;
        color: #0f111b;
      }

      .scene {
        min-height: 100vh;
        background: radial-gradient(circle at top left, #f7f9ff 0%, #e6ebf5 55%, #dbe1ee 100%);
        padding: clamp(32px, 6vw, 64px) 0;
        position: relative;
        overflow: hidden;
      }

      body[data-theme="dark"] .scene {
        background: radial-gradient(circle at top left, rgba(255, 255, 255, 0.08) 0%, #0f111b 45%, #07080f 100%);
      }

      .scene::before,
      .scene::after {
        content: "";
        position: absolute;
        width: clamp(220px, 40vw, 480px);
        height: clamp(220px, 40vw, 480px);
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.55);
        filter: blur(0px);
        opacity: 0.45;
        animation: float 18s ease-in-out infinite;
        pointer-events: none;
      }

      .scene::before {
        top: -15%;
        right: -5%;
        box-shadow: var(--shadow-soft);
      }

      .scene::after {
        bottom: -20%;
        left: -10%;
        background: rgba(255, 255, 255, 0.35);
        animation-delay: -6s;
      }

      .wrap {
        max-width: 960px;
        margin: 0 auto;
        padding: 0 clamp(20px, 5vw, 48px);
      }

      .page-shell {
        background: linear-gradient(135deg, var(--bg-raised), var(--bg-contrast));
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-soft);
        padding: clamp(32px, 4vw, 56px);
        backdrop-filter: blur(6px);
        position: relative;
      }

      .theme-toggle {
        position: absolute;
        top: clamp(24px, 3vw, 48px);
        right: clamp(24px, 5vw, 72px);
        border: none;
        border-radius: 999px;
        background: var(--bg-raised);
        box-shadow: var(--shadow-soft);
        padding: 8px 18px 8px 12px;
        display: inline-flex;
        align-items: center;
        gap: 12px;
        font-family: inherit;
        font-size: 0.82rem;
        letter-spacing: 0.08em;
        color: var(--text);
        cursor: pointer;
        transition: background var(--transition), box-shadow var(--transition), transform var(--transition);
        z-index: 2;
      }

      .theme-toggle:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 3px;
      }

      .theme-toggle:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-hover);
      }

      .toggle-track {
        width: 38px;
        height: 20px;
        border-radius: 999px;
        background: var(--bg-contrast);
        box-shadow: var(--shadow-inset);
        position: relative;
        padding: 3px;
      }

      .toggle-thumb {
        position: absolute;
        top: 3px;
        left: 3px;
        width: 14px;
        height: 14px;
        border-radius: 50%;
        background: var(--accent);
        transition: transform var(--transition);
      }

      body[data-theme="dark"] .toggle-thumb {
        transform: translateX(18px);
      }

      .toggle-label {
        text-transform: uppercase;
        letter-spacing: 0.2em;
      }

      .page-shell::after {
        content: "";
        position: absolute;
        inset: 18px;
        border-radius: calc(var(--radius-lg) - 4px);
        pointer-events: none;
        border: 1px solid rgba(255, 255, 255, 0.4);
        opacity: 0.35;
      }

      .h1 {
        font-size: clamp(2.6rem, 5vw, 3.4rem);
        margin: 24px 0 8px;
        letter-spacing: -0.04em;
        font-weight: 600;
      }

      .meta {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        font-size: 0.9rem;
        color: var(--muted);
        line-height: 1.4;
        align-items: center;
      }

      .meta-eyebrow {
        text-transform: uppercase;
        letter-spacing: 0.18em;
        font-size: 0.78rem;
      }

      .meta-spread {
        justify-content: space-between;
        align-items: center;
        gap: 16px;
      }

      .card {
        border-radius: var(--radius-md);
        padding: clamp(18px, 3vw, 26px);
        background: var(--bg-raised);
        box-shadow: var(--shadow-soft);
        border: 1px solid rgba(255, 255, 255, 0.5);
        transition: transform var(--transition), box-shadow var(--transition);
      }

      .card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-hover);
      }

      .featured-card {
        margin-top: 28px;
        padding-top: clamp(24px, 4vw, 34px);
      }

      .stack {
        display: grid;
        gap: 16px;
      }

      section + section {
        margin-top: 38px;
      }

      .sectionTitle {
        margin: 18px 0 14px;
        font-size: 0.78rem;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: var(--muted);
      }

      .sectionHeading {
        margin: 0 0 12px;
        font-size: 1.15rem;
        font-weight: 600;
        letter-spacing: -0.01em;
      }

      p {
        margin: 10px 0 0;
        line-height: 1.65;
        color: rgba(31, 35, 55, 0.92);
      }

      body[data-theme="dark"] p {
        color: rgba(244, 246, 255, 0.9);
      }

      a {
        color: var(--accent);
        text-decoration: none;
        font-weight: 500;
      }

      a:hover {
        text-decoration: underline;
      }

      .pill {
        display: inline-block;
        padding: 6px 14px;
        border-radius: 999px;
        font-size: 0.75rem;
        border: none;
        background: var(--bg-contrast);
        box-shadow: var(--shadow-inset);
        color: var(--muted);
      }

      .news-card {
        border-radius: 22px;
        padding: clamp(20px, 3vw, 28px);
      }

      .news-link {
        display: block;
        margin-top: 6px;
        font-weight: 600;
        font-size: 1.08rem;
        color: var(--text);
      }

      .news-link:hover {
        color: var(--accent);
      }

      .section-label {
        display: inline-flex;
        padding: 8px 18px;
        border-radius: 999px;
        background: var(--bg-contrast);
        box-shadow: var(--shadow-inset);
        font-size: 0.85rem;
        color: var(--muted);
        letter-spacing: 0.2em;
        text-transform: uppercase;
      }

      @media (max-width: 720px) {
        .h1 {
          font-size: 2.3rem;
        }

        .meta-spread {
          flex-direction: column;
          align-items: flex-start;
        }

        .card,
        .news-card {
          padding: 20px;
        }

        .theme-toggle {
          position: static;
          margin-bottom: 18px;
        }

        .scene {
          padding-top: 24px;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        * {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
        }
      }

      @keyframes float {
        0% {
          transform: translate3d(0, 0, 0);
        }
        50% {
          transform: translate3d(0, -25px, 0);
        }
        100% {
          transform: translate3d(0, 0, 0);
        }
      }
    </style>
  </head>
  <body data-theme="light">
    <div class="scene">
      <button class="theme-toggle" type="button" id="themeToggle" aria-pressed="false" aria-label="Cambiar modo de color">
        <span class="toggle-track">
          <span class="toggle-thumb"></span>
        </span>
        <span class="toggle-label">Modo oscuro</span>
      </button>
      <main class="wrap page-shell">
        <slot />
      </main>
    </div>
    <script is:inline>
      (function () {
        const storageKey = "theme-preference";
        const body = document.body;
        const toggle = document.getElementById("themeToggle");
        const mediaQuery = window.matchMedia("(prefers-color-scheme: dark)");

        const getPreference = () => localStorage.getItem(storageKey) || (mediaQuery.matches ? "dark" : "light");

        const applyTheme = (theme) => {
          body.dataset.theme = theme;
          toggle?.setAttribute("aria-pressed", theme === "dark" ? "true" : "false");
        };

        const setTheme = (theme) => {
          localStorage.setItem(storageKey, theme);
          applyTheme(theme);
        };

        applyTheme(getPreference());

        toggle?.addEventListener("click", () => {
          setTheme(body.dataset.theme === "dark" ? "light" : "dark");
        });

        mediaQuery.addEventListener("change", (event) => {
          if (!localStorage.getItem(storageKey)) {
            applyTheme(event.matches ? "dark" : "light");
          }
        });
      })();
    </script>
  </body>
</html>