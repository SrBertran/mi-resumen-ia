---
const { item, showWhy = true } = Astro.props;

function formatDate(iso) {
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return iso;
  return new Intl.DateTimeFormat("es-ES", { dateStyle: "medium", timeStyle: "short" }).format(d);
}
---

<article class="card news-card">
  <div class="meta">
    <span>{item.source}</span>
    <span>·</span>
    <time datetime={item.published_at}>{formatDate(item.published_at)}</time>
  </div>

  <a
    class="news-link"
    href={item.url}
    target="_blank"
    rel="noreferrer"
  >
    {item.title}
  </a>

  {item.summary && <p>{item.summary}</p>}
  {showWhy && item.why_it_matters && <p style="opacity:.9">{item.why_it_matters}</p>}

  {item.tags?.length ? (
    <div class="tag-row">
      {item.tags.map((t) => <span class="tag-label"><strong>Tag:</strong>&nbsp;{t}</span>)}
    </div>
  ) : null}
</article>